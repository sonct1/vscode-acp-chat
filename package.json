{
  "name": "vscode-acp-chat",
  "displayName": "VSCode ACP Chat",
  "description": "AI coding agents in VS Code via Agent Client Protocol (ACP). Chat with Claude, OpenCode, and other ACP-compatible agents directly in your editor.",
  "version": "1.5.0",
  "publisher": "fiyqkrc",
  "license": "MIT",
  "icon": "assets/icon.png",
  "preview": true,
  "pricing": "Free",
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pengjiantao/vscode-acp-chat"
  },
  "bugs": {
    "url": "https://github.com/pengjiantao/vscode-acp-chat/issues"
  },
  "homepage": "https://github.com/pengjiantao/vscode-acp-chat#readme",
  "engines": {
    "vscode": "^1.74.0",
    "node": "^22"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "opencode",
    "acp",
    "agent",
    "chat",
    "copilot",
    "coding assistant",
    "llm"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "The extension can run in untrusted workspaces but some features may be limited."
    },
    "virtualWorkspaces": true
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-acp-chat.startChat",
        "title": "Start Chat",
        "category": "ACP",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vscode-acp-chat.newChat",
        "title": "New Chat",
        "category": "ACP",
        "icon": "$(add)"
      },
      {
        "command": "vscode-acp-chat.clearChat",
        "title": "Clear Chat",
        "category": "ACP",
        "icon": "$(clear-all)"
      },
      {
        "command": "vscode-acp-chat.loadHistory",
        "title": "Load History",
        "category": "ACP",
        "icon": "$(history)"
      },
      {
        "command": "vscode-acp-chat.selectAgent",
        "title": "Select Agent",
        "category": "ACP",
        "icon": "$(robot)"
      },
      {
        "command": "vscode-acp-chat.sendSelectionToChat",
        "title": "Send to ACP",
        "category": "ACP",
        "icon": "$(send)"
      },
      {
        "command": "vscode-acp-chat.sendTerminalSelectionToChat",
        "title": "Send to ACP",
        "category": "ACP",
        "icon": "$(send)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-acp-chat",
          "title": "VSCode ACP",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "vscode-acp-chat": [
        {
          "type": "webview",
          "id": "vscode-acp-chat.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)",
          "contextualTitle": "ACP Chat"
        }
      ]
    },
    "configuration": {
      "title": "ACP",
      "properties": {
        "vscode-acp-chat.enableDiffSummary": {
          "type": "boolean",
          "default": true,
          "description": "Enable the collective diff summary for file modifications."
        },
        "vscode-acp-chat.passMcpServers": {
          "type": "boolean",
          "default": true,
          "description": "Whether to pass MCP server configurations to the agent via ACP newSession/loadSession requests."
        },
        "vscode-acp-chat.customAgents": {
          "type": "array",
          "default": [],
          "description": "Custom agent configurations. These will be merged with built-in agents, with custom agents taking precedence for matching IDs.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "command",
              "args"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the agent"
              },
              "name": {
                "type": "string",
                "description": "Display name for the agent"
              },
              "command": {
                "type": "string",
                "description": "Command to execute (e.g., 'npx', 'goose')"
              },
              "args": {
                "type": "array",
                "description": "Arguments to pass to the command",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "description": "Environment variables to set for the agent process",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "vscode-acp-chat.sendSelectionToChat",
          "when": "editorHasSelection",
          "group": "acp@1"
        }
      ],
      "terminal/context": [
        {
          "command": "vscode-acp-chat.sendTerminalSelectionToChat",
          "when": "terminalTextSelected",
          "group": "acp@1"
        }
      ],
      "view/title": [
        {
          "command": "vscode-acp-chat.selectAgent",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@0"
        },
        {
          "command": "vscode-acp-chat.newChat",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@1"
        },
        {
          "command": "vscode-acp-chat.clearChat",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@2"
        },
        {
          "command": "vscode-acp-chat.loadHistory",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "vscode-acp-chat.startChat",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.newChat",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.clearChat",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.loadHistory",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "test": "vscode-test",
    "precoverage": "npm run compile-tests && npm run compile",
    "coverage": "vscode-test --coverage --coverage-output coverage --coverage-reporter lcov --coverage-reporter text",
    "coverage:html": "vscode-test --coverage --coverage-reporter html",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@types/highlight.js": "^9.12.4",
    "@types/jsdom": "^27.0.0",
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@vscode/codicons": "^0.0.45",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.1",
    "vscode-jsonrpc": "^8.2.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
