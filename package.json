{
  "name": "vscode-acp-chat",
  "displayName": "VSCode ACP Chat",
  "description": "AI coding agents in VS Code via Agent Client Protocol (ACP). Chat with Claude, OpenCode, and other ACP-compatible agents directly in your editor.",
  "version": "1.18.8",
  "publisher": "fiyqkrc",
  "license": "MIT",
  "icon": "assets/icon.png",
  "preview": true,
  "pricing": "Free",
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pengjiantao/vscode-acp-chat"
  },
  "bugs": {
    "url": "https://github.com/pengjiantao/vscode-acp-chat/issues"
  },
  "homepage": "https://github.com/pengjiantao/vscode-acp-chat#readme",
  "engines": {
    "vscode": "^1.101.0",
    "node": "^22"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "opencode",
    "codebuddy",
    "acp",
    "agent",
    "chat",
    "copilot",
    "coding assistant",
    "llm"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "The extension can run in untrusted workspaces but some features may be limited."
    },
    "virtualWorkspaces": true
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-acp-chat.startChat",
        "title": "Start Chat",
        "category": "ACP",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vscode-acp-chat.newChat",
        "title": "New Chat",
        "category": "ACP",
        "icon": "$(add)"
      },
      {
        "command": "vscode-acp-chat.clearChat",
        "title": "Clear Chat",
        "category": "ACP",
        "icon": "$(clear-all)"
      },
      {
        "command": "vscode-acp-chat.manageSessions",
        "title": "Manage Chat Sessions",
        "category": "ACP",
        "icon": "$(list-tree)",
        "enablement": "config.vscode-acp-chat.multiSession.enabled && !vscode-acp-chat.multiSessionUnavailable"
      },
      {
        "command": "vscode-acp-chat.switchSession",
        "title": "Switch Chat Session",
        "category": "ACP",
        "icon": "$(list-selection)"
      },
      {
        "command": "vscode-acp-chat.loadHistory",
        "title": "Load History",
        "category": "ACP",
        "icon": "$(history)"
      },
      {
        "command": "vscode-acp-chat.openSettings",
        "title": "Open ACP Settings",
        "category": "ACP",
        "icon": "$(gear)"
      },
      {
        "command": "vscode-acp-chat.deleteHistorySession",
        "title": "Delete History Session",
        "category": "ACP",
        "icon": "$(trash)"
      },
      {
        "command": "vscode-acp-chat.selectAgent",
        "title": "Select Agent",
        "category": "ACP",
        "icon": "$(robot)"
      },
      {
        "command": "vscode-acp-chat.sendSelectionToChat",
        "title": "ACP: Add Selection to Chat",
        "icon": "$(add)"
      },
      {
        "command": "vscode-acp-chat.sendTerminalSelectionToChat",
        "title": "ACP: Add Terminal Selection to Chat",
        "icon": "$(add)"
      },
      {
        "command": "vscode-acp-chat.addFileToChat",
        "title": "ACP: Add File to Chat",
        "icon": "$(file-add)"
      },
      {
        "command": "vscode-acp-chat.addFolderToChat",
        "title": "ACP: Add Folder to Chat",
        "icon": "$(new-folder)"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "vscode-acp-chat-secondary",
          "title": "ACP CHAT",
          "icon": "assets/icon.svg"
        }
      ],
      "activitybar": [
        {
          "id": "vscode-acp-chat-session-manager",
          "title": "ACP Sessions",
          "icon": "assets/session-manager.svg"
        }
      ]
    },
    "views": {
      "vscode-acp-chat-secondary": [
        {
          "type": "webview",
          "id": "vscode-acp-chat.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)",
          "contextualTitle": "ACP Chat"
        }
      ],
      "vscode-acp-chat-session-manager": [
        {
          "type": "webview",
          "id": "vscode-acp-chat.sessionManagerView",
          "name": "Sessions",
          "contextualTitle": "ACP Sessions",
          "when": "config.vscode-acp-chat.multiSession.enabled && !vscode-acp-chat.multiSessionUnavailable"
        }
      ]
    },
    "configuration": {
      "title": "ACP",
      "properties": {
        "vscode-acp-chat.enableDiffSummary": {
          "type": "boolean",
          "default": true,
          "description": "Enable the collective diff summary for file modifications."
        },
        "vscode-acp-chat.autoScroll.bottomThreshold": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 500,
          "description": "Distance from the bottom of the chat transcript in pixels below which auto-scroll remains enabled. A value of 0 means only the exact bottom keeps auto-scroll active. Default 100."
        },
        "vscode-acp-chat.autoScroll.settleFrames": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 20,
          "description": "Number of animation frames to keep pinning the chat transcript to the bottom after each content change. Higher values reduce missed bottom-locking during streaming at the cost of stronger bottom pinning. Default 3."
        },
        "vscode-acp-chat.fontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 40,
          "description": "Uniform normal-text size for the primary chat webview in pixels. Set to 0 to follow the VS Code font size. Positive values are clamped to 8-40 px; Markdown headings may be slightly larger, while fixed icons and the ACP Sessions manager are excluded."
        },
        "vscode-acp-chat.multiSession.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable concurrent multi-session chat. When disabled, the legacy single-session workflow is used."
        },
        "vscode-acp-chat.multiSession.lowResourceMode": {
          "type": "boolean",
          "default": true,
          "description": "Reduce CPU and memory usage in multi-session mode by disabling per-session diff tracking, file watchers, conflict telemetry, and manager diff badges. Disable this when you need multi-session diff review actions."
        },
        "vscode-acp-chat.multiSession.maxConcurrentSessions": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Maximum number of started local ACP sessions/processes allowed concurrently. Draft sessions do not count toward this limit."
        },
        "vscode-acp-chat.passMcpServers": {
          "type": "boolean",
          "default": true,
          "description": "Whether to pass MCP server configurations to the agent via ACP newSession/loadSession requests."
        },
        "vscode-acp-chat.enableDocumentSync": {
          "type": "boolean",
          "default": true,
          "description": "Send document open/close/change/save/focus notifications to the ACP agent. Requires agent support for NES document events."
        },
        "vscode-acp-chat.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for raw ACP session update events."
        },
        "vscode-acp-chat.enablePersistentSessions": {
          "type": "boolean",
          "default": true,
          "description": "Persist session history across VS Code restarts. When disabled, sessions are only remembered until the extension is closed."
        },
        "vscode-acp-chat.sessionRetentionDays": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "Automatically remove persisted sessions older than this many days."
        },
        "vscode-acp-chat.maxSessionsPerAgent": {
          "type": "number",
          "default": 300,
          "minimum": 1,
          "description": "Maximum number of persisted sessions to keep per agent. Oldest sessions are removed first."
        },
        "vscode-acp-chat.antigravity.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the bundled experimental Antigravity ACP adapter. Google states that third-party access using Antigravity OAuth may violate the Antigravity Terms of Service and may result in account suspension or termination. See https://antigravity.google/terms and https://antigravity.google/docs/faq before enabling."
        },
        "vscode-acp-chat.swarmAgent.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the bundled experimental Swarm ACP root orchestrator. Swarm reads user-defined roles and workflows from the workspace and can spawn multiple worker ACP agents."
        },
        "vscode-acp-chat.swarmAgent.configDirectory": {
          "type": "string",
          "default": ".vscode/acp-swarm",
          "description": "Workspace-relative or absolute directory containing Swarm roles, workflows, and swarm.config.json."
        },
        "vscode-acp-chat.swarmAgent.defaultWorkflow": {
          "type": "string",
          "default": "default",
          "description": "Default Swarm workflow id to execute for new Swarm prompts."
        },
        "vscode-acp-chat.swarmAgent.maxWorkers": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Maximum number of concurrent Swarm worker ACP sessions."
        },
        "vscode-acp-chat.swarmAgent.requireApprovalBeforeWrites": {
          "type": "boolean",
          "default": true,
          "description": "Require client permission before Swarm forwards write-capable worker actions."
        },
        "vscode-acp-chat.swarmAgent.testLockPatterns": {
          "type": "array",
          "default": ["npm test", "npm run test", "cargo test", "go test", "pytest"],
          "description": "Terminal command fragments that acquire the Swarm test_runner lock.",
          "items": {
            "type": "string"
          }
        },
        "vscode-acp-chat.pi.historyLoadMode": {
          "type": "string",
          "enum": [
            "full",
            "compacted"
          ],
          "default": "full",
          "description": "Controls how the bundled Pi agent replays session history. 'full' reads the active-path transcript from Pi JSONL files; 'compacted' uses Pi's compacted get_messages RPC context."
        },
        "vscode-acp-chat.customAgents": {
          "type": "array",
          "default": [],
          "description": "Custom agent configurations. These will be merged with built-in agents, with custom agents taking precedence for matching IDs.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "command",
              "args"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the agent"
              },
              "name": {
                "type": "string",
                "description": "Display name for the agent"
              },
              "command": {
                "type": "string",
                "description": "Command to execute (e.g., 'npx', 'goose')"
              },
              "args": {
                "type": "array",
                "description": "Arguments to pass to the command",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "description": "Environment variables to set for the agent process",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "availabilityCommand": {
                "type": "string",
                "description": "Optional command used only for availability checks. Defaults to command."
              }
            }
          }
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "vscode-acp-chat.sendSelectionToChat",
          "when": "editorHasSelection",
          "group": "acp@1"
        }
      ],
      "terminal/context": [
        {
          "command": "vscode-acp-chat.sendTerminalSelectionToChat",
          "when": "terminalTextSelected",
          "group": "acp@1"
        }
      ],
      "explorer/context": [
        {
          "command": "vscode-acp-chat.addFileToChat",
          "when": "explorerResourceIsFolder == false",
          "group": "acp@1"
        },
        {
          "command": "vscode-acp-chat.addFolderToChat",
          "when": "explorerResourceIsFolder == true",
          "group": "acp@2"
        }
      ],
      "editor/title": [
        {
          "command": "vscode-acp-chat.addFileToChat",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "command": "vscode-acp-chat.addFileToChat",
          "when": "resourceScheme == file",
          "group": "acp@1"
        }
      ],
      "view/title": [
        {
          "command": "vscode-acp-chat.selectAgent",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@0"
        },
        {
          "command": "vscode-acp-chat.newChat",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@1"
        },
        {
          "command": "vscode-acp-chat.manageSessions",
          "when": "view == vscode-acp-chat.chatView && config.vscode-acp-chat.multiSession.enabled && !vscode-acp-chat.multiSessionUnavailable",
          "group": "navigation@2"
        },
        {
          "command": "vscode-acp-chat.switchSession",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@3"
        },
        {
          "command": "vscode-acp-chat.clearChat",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@4"
        },
        {
          "command": "vscode-acp-chat.loadHistory",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@5"
        },
        {
          "command": "vscode-acp-chat.openSettings",
          "when": "view == vscode-acp-chat.chatView",
          "group": "navigation@6"
        }
      ],
      "commandPalette": [
        {
          "command": "vscode-acp-chat.startChat",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.newChat",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.manageSessions",
          "when": "config.vscode-acp-chat.multiSession.enabled && !vscode-acp-chat.multiSessionUnavailable"
        },
        {
          "command": "vscode-acp-chat.switchSession",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.clearChat",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.loadHistory",
          "when": "true"
        },
        {
          "command": "vscode-acp-chat.deleteHistorySession",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit && npm run typecheck:antigravity-adapter",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "pretest": "npm run test:antigravity-adapter && npm run compile-tests && npm run compile",
    "test": "vscode-test",
    "typecheck:antigravity-adapter": "tsc -p src/features/antigravity-agent/vendor/antigravity-acp/tsconfig.json --noEmit",
    "test:antigravity-adapter": "npm run typecheck:antigravity-adapter && tsc -p src/features/antigravity-agent/vendor/antigravity-acp/tsconfig.test.json && node --experimental-specifier-resolution=node --test src/features/antigravity-agent/vendor/antigravity-acp/.tmp-tests/tests/*.test.js && node scripts/smoke-antigravity-adapter.mjs",
    "precoverage": "npm run compile-tests && npm run compile",
    "coverage": "vscode-test --coverage --coverage-output coverage --coverage-reporter lcov --coverage-reporter text",
    "coverage:html": "vscode-test --coverage --coverage-reporter html",
    "lint": "eslint src --fix --ignore-pattern 'src/features/pi-agent/vendor/**' --ignore-pattern 'src/features/antigravity-agent/vendor/**'",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "prepare": "husky",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/highlight.js": "^9.12.4",
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.17.0",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@bufbuild/protobuf": "2.12.1",
    "@baybreezy/file-extension-icon": "^0.0.5",
    "@vscode/codicons": "^0.0.45",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "zod": "^3.25.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "esbuild@0.25.12": true,
    "keytar@7.9.0": true
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
